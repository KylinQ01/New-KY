---
import fs from "node:fs";
import path from "node:path";
import { footerConfig, profileConfig } from "@/config";
import { url } from "@/utils/url-utils";

const currentYear = new Date().getFullYear();

let customFooterHtml = "";
if (footerConfig.enable) {
  try {
    const footerConfigPath = path.join(
      process.cwd(),
      "src",
      "config",
      "FooterConfig.html",
    );
    customFooterHtml = fs.readFileSync(footerConfigPath, "utf-8");
    customFooterHtml = customFooterHtml.replace(/<!--[\s\S]*?-->/g, "").trim();
  } catch (error) {
    console.warn("FooterConfig.html 读取失败:", error.message);
  }
}
---


<!-- 渐变分割线 -->
<hr class="divider-gradient !mx-8 md:!mx-32" />

<div
  class="footer-card transition rounded-2xl mb-12 mx-4 md:mx-32 px-6 py-8 flex flex-col items-center justify-center relative overflow-hidden"
>
  <!-- 背景装饰光球 -->
  <div class="footer-orb footer-orb-1"></div>
  <div class="footer-orb footer-orb-2"></div>
  <div class="footer-orb footer-orb-3"></div>

  <!-- 顶部装饰线 -->
  <div class="footer-top-line"></div>

  <div class="transition text-50 text-sm text-center wrap max-w-2xl relative z-10">
    {customFooterHtml && (
      <div class="mb-4 pb-4 border-b border-(--line-divider) text-(--content-meta) leading-relaxed" set:html={customFooterHtml} />
    )}

    <!-- 版权与链接 -->
    <div class="flex gap-2 justify-center flex-wrap items-center">
      &copy; <span id="copyright-year">{currentYear}</span>
      <span class="font-semibold text-(--primary) footer-name-glow">{profileConfig.name}</span>
      <span class="text-(--content-meta)">· All Rights Reserved ·</span>
      <a
        class="transition link text-(--primary) font-medium hover:underline"
        target="_blank"
        href={url("rss.xml")}>RSS</a
      >
      <span class="text-(--line-color)" aria-hidden="true">/</span>
      <a
        class="transition link text-(--primary) font-medium hover:underline"
        target="_blank"
        href={url("sitemap-index.xml")}>Sitemap</a
      >
    </div>

    <!-- 驱动信息 -->
    <div class="mt-3 flex gap-2 justify-center flex-wrap text-(--content-meta) text-xs">
      <span>Powered by</span>
      <a
        class="transition link text-(--primary) font-medium hover:underline"
        target="_blank"
        href="https://astro.build">Astro</a
      >
      <span aria-hidden="true">&</span>
      <a
        class="transition link text-(--primary) font-medium hover:underline"
        target="_blank"
        href="https://github.com/CuteLeaf/Firefly">Firefly</a
      >
      <span class="text-(--line-color) px-1">|</span>
      <span>Theme</span>
      <span class="text-(--primary)/70 font-medium">Firefly</span>
    </div>

    <!-- 访客计数 -->
    <div id="visitor-counter" class="mt-4 flex gap-1.5 justify-center flex-wrap text-xs text-neutral-400 dark:text-neutral-500">
      <span>👋 您是第</span>
      <span id="busuanzi_value_site_uv" class="font-bold text-(--primary)" style="font-size:1.1em">--</span>
      <span>位来访者</span>
    </div>
  </div>

  <!-- 底部装饰线 -->
  <div class="footer-bottom-line"></div>
</div>

<style>
  /* 页脚卡片渐变背景 */
  .footer-card {
    background:
      radial-gradient(ellipse at 20% 0%, color-mix(in oklch, var(--primary) 12%, transparent) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, color-mix(in oklch, var(--primary) 10%, transparent) 0%, transparent 50%),
      var(--card-bg);
    box-shadow:
      0 8px 32px -8px color-mix(in oklch, var(--primary) 20%, transparent),
      var(--shadow-sm);
    border: 1px solid color-mix(in oklch, var(--primary) 15%, var(--line-divider));
    position: relative;
  }

  :root.dark .footer-card {
    background:
      radial-gradient(ellipse at 20% 0%, color-mix(in oklch, var(--primary) 18%, transparent) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, color-mix(in oklch, var(--primary) 15%, transparent) 0%, transparent 50%),
      var(--card-bg);
    box-shadow:
      0 8px 32px -8px color-mix(in oklch, var(--primary) 30%, transparent),
      var(--shadow-sm);
  }

  /* 页脚装饰光球 */
  .footer-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
  }

  .footer-orb-1 {
    width: 200px;
    height: 200px;
    top: -80px;
    left: -60px;
    background: color-mix(in oklch, var(--primary) 40%, #ff6b6b);
    opacity: 0.3;
    animation: footer-orb-float-1 8s ease-in-out infinite;
  }

  .footer-orb-2 {
    width: 160px;
    height: 160px;
    top: 50%;
    right: -60px;
    background: color-mix(in oklch, var(--primary) 35%, #4ecdc4);
    opacity: 0.25;
    animation: footer-orb-float-2 10s ease-in-out infinite;
  }

  .footer-orb-3 {
    width: 140px;
    height: 140px;
    bottom: -60px;
    left: 30%;
    background: color-mix(in oklch, var(--primary) 30%, #a8e6cf);
    opacity: 0.2;
    animation: footer-orb-float-3 12s ease-in-out infinite;
  }

  @keyframes footer-orb-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, 20px) scale(1.1); }
  }

  @keyframes footer-orb-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-25px, -15px) scale(0.95); }
  }

  @keyframes footer-orb-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, -25px) scale(1.05); }
  }

  /* 顶部装饰线 */
  .footer-top-line {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      color-mix(in oklch, var(--primary) 50%, transparent) 30%,
      var(--primary) 50%,
      color-mix(in oklch, var(--primary) 50%, transparent) 70%,
      transparent 100%
    );
    opacity: 0.6;
  }

  /* 底部装饰线 */
  .footer-bottom-line {
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      color-mix(in oklch, var(--primary) 30%, transparent) 50%,
      transparent 100%
    );
    opacity: 0.4;
  }

  /* 名字发光效果 */
  .footer-name-glow {
    text-shadow: 0 0 12px color-mix(in oklch, var(--primary) 40%, transparent);
    animation: name-glow-pulse 3s ease-in-out infinite;
  }

  @keyframes name-glow-pulse {
    0%, 100% { text-shadow: 0 0 8px color-mix(in oklch, var(--primary) 30%, transparent); }
    50% { text-shadow: 0 0 16px color-mix(in oklch, var(--primary) 50%, transparent); }
  }
</style>

<script is:inline>
(function() {
  var b = document.createElement("script");
  b.src = "https://busuanzi.icodeq.com/busuanzi.pure.mini.js";
  b.async = true;
  document.head.appendChild(b);
})();
</script>