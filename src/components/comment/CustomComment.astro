---
import type { CollectionEntry } from "astro:content";
import { removeFileExtension } from "@/utils/url-utils";

interface Props {
  post?: CollectionEntry<"posts"> | CollectionEntry<"spec">;
  customPath?: string;
  slug?: string;
}

const { post, customPath, slug: passedSlug } = Astro.props as Props;
const slugFromPath = (customPath || "/").replace(/^\/+|\/+$/g, "") || "index";
const slug = post ? removeFileExtension(post.id) : slugFromPath;
const commentSlug = passedSlug || slug || '/';
---

<!-- CustomComment - 使用自建 API 的评论系统 -->
<div id="post-comments" class="card-base p-8 mb-6 relative overflow-hidden">
  <!-- 装饰背景 -->
  <div class="absolute top-0 right-0 w-32 h-32 opacity-5 pointer-events-none">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="50" cy="50" r="40" fill="currentColor" class="text-(--primary)" />
      <circle cx="50" cy="50" r="25" fill="none" stroke="currentColor" stroke-width="2" class="text-(--primary)" />
      <circle cx="50" cy="50" r="10" fill="currentColor" class="text-(--primary)" />
    </svg>
  </div>
  <!-- 评论区标题 -->
  <div class="relative z-10 mb-6">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-1 h-6 bg-linear-to-b from-(--primary) to-transparent rounded-full"></div>
      <h3 class="text-xl font-bold text-(--btn-content)">💬 评论区</h3>
    </div>
    <p class="text-sm text-(--content-meta) ml-4">分享你的想法，与大家交流讨论</p>
  </div>
  <!-- 评论内容区域 -->
  <div class="relative z-10 pl-2 pr-2">
    <!-- 评论列表 -->
    <div id="comments-list" class="space-y-4">
      <p class="text-center text-(--content-meta) py-4">加载中...</p>
    </div>
    <!-- 评论表单 -->
    <div class="mt-6 pt-6 border-t border-(--line-divider)">
      <h4 class="font-semibold text-(--text-main) mb-3">✍️ 发表评论</h4>
      <form id="comment-form" class="space-y-3">
        <input type="hidden" id="reply-to-id" value="" />
        <div id="reply-preview" class="hidden mb-3 p-3 bg-(--card-bg) border border-(--line-color) rounded-lg">
          <span id="reply-preview-text" class="text-sm text-(--content-meta)"></span>
          <button type="button" id="cancel-reply" class="ml-2 text-xs text-(--primary) hover:underline">取消回复</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <input type="text" id="comment-name" placeholder="昵称（必填）" class="w-full p-3 rounded-xl border border-(--line-color) bg-(--card-bg) text-(--text-main) focus:outline-none focus:border-(--primary) transition" />
          <input type="email" id="comment-email" placeholder="邮箱（选填）" class="w-full p-3 rounded-xl border border-(--line-color) bg-(--card-bg) text-(--text-main) focus:outline-none focus:border-(--primary) transition" />
        </div>
        <textarea id="comment-content" placeholder="欢迎留言，你们的留言我都会看" required class="w-full p-3 rounded-xl border border-(--line-color) bg-(--card-bg) text-(--text-main) focus:outline-none focus:border-(--primary) transition min-h-[100px] resize-y"></textarea>
        <button type="submit" class="btn btn-primary" id="submit-btn">提交评论</button>
      </form>
    </div>
  </div>
</div>

<script define:vars={{ commentSlug }}>
  document.addEventListener('DOMContentLoaded', function () {
    var currentSlug = commentSlug || '/';
    var commentApiUrl = 'https://api.kylinqaq.xyz/api/public/comments/' + currentSlug;
    var commentSubmitUrl = 'https://api.kylinqaq.xyz/api/comments';
    var allComments = [];
    var replyingTo = null;

    // 加载评论
    function loadComments() {
      fetch(commentApiUrl)
        .then(function (res) { return res.json(); })
        .then(function (comments) {
          allComments = comments;
          // 过滤出顶级评论
          var topComments = allComments.filter(function (c) {
            return !c.parent_id || c.parent_id === null || c.parent_id === undefined || parseInt(c.parent_id) === 0;
          });
          renderComments(topComments);
        })
        .catch(function () {
          var container = document.getElementById('comments-list');
          if (container) {
            container.innerHTML = '<p class="text-center text-(--content-meta) py-4">评论加载失败，请稍后重试</p>';
          }
        });
    }

    // 渲染评论（支持嵌套）
    function renderComments(comments) {
      var container = document.getElementById('comments-list');
      if (!container) return;

      if (comments.length === 0) {
        container.innerHTML = '<p class="text-center text-(--content-meta) py-4">暂无评论，快来抢沙发吧！</p>';
        return;
      }

      var html = '';
      comments.forEach(function (c) {
        html += renderComment(c, 0);
      });
      container.innerHTML = html;

      bindReplyButtons();
    }

    // 递归渲染评论
    function renderComment(c, level) {
      // 查找子评论（确保类型匹配）
      var replies = allComments.filter(function (r) {
        return r.parent_id != null && parseInt(r.parent_id) === parseInt(c.id);
      });

      var padding = level * 32;
      var html = '';
      html += '<div class="p-4 rounded-xl bg-(--card-bg) border border-(--line-color)" style="margin-left:' + padding + 'px">';
      html += '<div class="flex items-center justify-between mb-2">';
      html += '<div class="flex items-center gap-2">';
      html += '<span class="font-semibold text-(--primary)">' + (c.name || '匿名用户') + '</span>';
      html += '<span class="text-xs text-(--content-meta)">' + formatDate(c.created_at) + '</span>';
      html += '</div>';
      html += '<button type="button" class="text-xs text-(--primary) hover:underline reply-btn" data-id="' + c.id + '" data-name="' + (c.name || '匿名用户') + '">回复</button>';
      html += '</div>';
      html += '<p class="text-(--text-main)">' + (c.content || '') + '</p>';
      html += '</div>';

      // 子评论
      if (replies.length > 0) {
        replies.forEach(function (r) {
          html += renderComment(r, level + 1);
        });
      }

      return html;
    }

    // 格式化日期
    function formatDate(dateStr) {
      var date = new Date(dateStr);
      var now = new Date();
      var diff = now - date;
      var seconds = Math.floor(diff / 1000);
      var minutes = Math.floor(seconds / 60);
      var hours = Math.floor(minutes / 60);
      var days = Math.floor(hours / 24);

      if (seconds < 60) return '刚刚';
      if (minutes < 60) return minutes + '分钟前';
      if (hours < 24) return hours + '小时前';
      if (days < 7) return days + '天前';
      return date.toLocaleDateString('zh-CN');
    }

    // 绑定回复按钮
    function bindReplyButtons() {
      var replyBtns = document.querySelectorAll('.reply-btn');
      replyBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var commentId = btn.getAttribute('data-id');
          var commenterName = btn.getAttribute('data-name');
          replyingTo = commentId;

          var replyPreview = document.getElementById('reply-preview');
          var replyPreviewText = document.getElementById('reply-preview-text');
          replyPreviewText.textContent = '回复 @' + commenterName + '：';
          replyPreview.classList.remove('hidden');

          document.getElementById('reply-to-id').value = commentId;
          document.getElementById('submit-btn').textContent = '提交回复';
          document.getElementById('comment-content').focus();
        });
      });

      var cancelBtn = document.getElementById('cancel-reply');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', function () {
          document.getElementById('reply-to-id').value = '';
          document.getElementById('reply-preview').classList.add('hidden');
          document.getElementById('submit-btn').textContent = '提交评论';
        });
      }
    }

    // 提交评论
    var form = document.getElementById('comment-form');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var name = document.getElementById('comment-name').value;
        var email = document.getElementById('comment-email').value;
        var content = document.getElementById('comment-content').value;
        var parent_id = document.getElementById('reply-to-id').value;
        if (!content) { alert('请输入评论内容'); return; }

        var xhr = new XMLHttpRequest();
        xhr.open('POST', commentSubmitUrl, true);
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onreadystatechange = function () {
          if (xhr.readyState === 4) {
            try {
              var data = JSON.parse(xhr.responseText);
              if (data.success) {
                alert('评论提交成功！');
                document.getElementById('comment-form').reset();
                document.getElementById('reply-to-id').value = '';
                document.getElementById('reply-preview').classList.add('hidden');
                document.getElementById('submit-btn').textContent = '提交评论';
                loadComments();
              } else {
                alert(data.error || '提交失败');
              }
            } catch (err) {
              alert('提交失败，请重试');
            }
          }
        };
        var payload = { post_slug: currentSlug, name: name, email: email, content: content };
        if (parent_id) {
          payload.parent_id = parseInt(parent_id);
        }
        xhr.send(JSON.stringify(payload));
      });
    }

    // 初始化
    loadComments();
  });
</script>